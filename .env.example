# Copy to .env.local and fill in.

# --- Supabase ---
# From Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Server-only, never expose to the client. Labeled "secret key" in newer
# Supabase dashboards; older projects call this the "service_role" key.
SUPABASE_SECRET_KEY=

# --- Database ---
# Use the Supabase "Transaction" pooler connection string for the app,
# or the direct connection string for migrations. The same URL works for both
# in dev.
DATABASE_URL=

# --- Site ---
# Used for Supabase email confirmation redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Plaid (added in a later step) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# 32 random bytes, base64-encoded. Generate with: openssl rand -base64 32
# Used to encrypt plaid access tokens at rest. Losing this means re-linking
# every connected institution, so back it up alongside your other secrets.
PLAID_TOKEN_ENCRYPTION_KEY=

# --- Cron ---
# Shared secret Vercel Cron sends as `Authorization: Bearer ${CRON_SECRET}`.
# Set in Vercel project env; not needed locally unless you want to hit
# /api/cron/snapshot manually. Generate with: openssl rand -base64 32
CRON_SECRET=

# --- Sentry (optional) ---
# DSN from sentry.io > Project Settings > Client Keys (DSN).
# Public by design — it identifies the project, not a secret. Leave empty
# locally to disable Sentry; server + client init become no-ops.
NEXT_PUBLIC_SENTRY_DSN=
# Optional environment tag. Defaults to VERCEL_ENV on Vercel, "development" locally.
SENTRY_ENVIRONMENT=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# Build-time source map upload. Only needed in CI / production builds.
# Auth token from sentry.io > Settings > Auth Tokens (scope: project:releases).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Admin allowlist ---
# Comma-separated email list. Anyone signed in with one of these emails can
# reach /admin/waitlist and issue invite tokens. Unset = no admins, /admin
# routes 404.
ADMIN_EMAILS=
